# Google Analytics
# Get your GA4 Measurement ID from https://analytics.google.com/
# It should look like: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga4_measurement_id_here

# Enable Analytics in Development (optional - set to 'true' to test analytics locally)
# Note: In production, analytics is always enabled
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Frontend Platform URL (optional - defaults to https://app.jenesisai.com)
NEXT_PUBLIC_FRONTEND_PLATFORM_URL=https://app.jenesisai.com
